# Node Environment
NODE_ENV=production

# Server Configuration
PORT=3001
DATABASE_PATH=./db.sqlite

# JWT Configuration
JWT_SECRET=your_very_secure_random_jwt_secret_key_here
JWT_REFRESH_SECRET=your_very_secure_random_refresh_secret_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Configuration (Hostinger SMTP)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM=noreply@yourdomain.com
ADMIN_EMAIL=admin@yourdomain.com

# CORS Configuration
# For local development, include localhost addresses
# For production, use only your domain
CORS_ORIGINS=https://turabroot.com,https://www.turabroot.com
FRONTEND_URL=https://turabroot.com

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Database Configuration
DATABASE_BACKUP_PATH=./backups
